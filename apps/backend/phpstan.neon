includes:
    - vendor/larastan/larastan/extension.neon
    - vendor/pestphp/pest/extension.neon

parameters:
    level: 9

    treatPhpDocTypesAsCertain: false

    paths:
        - app
        - database
        - tests

    excludePaths:
        - vendor
        - storage
        - bootstrap/cache

    ignoreErrors:
        # Limitations connues de l'intégration PHPStan / Pest-Plugin-Laravel
        - identifier: method.notFound
          path: tests
        - identifier: missingType.return
          path: tests
        # auth()->user() nullable dans les tests — toujours authentifié via actingAs()
        - identifier: method.nonObject
          path: tests
